# =========================================================
# MirsanLab Frontend - Environment template
# =========================================================
# Copiar este archivo a .env y ajustar por entorno.
# Nota: Angular CLI no consume .env automaticamente.
# Usar estas variables desde CI/CD, scripts o reemplazos
# de archivos de environment en build/deploy.

# -----------------------------
# App / Build
# -----------------------------
APP_ENV=development
APP_NAME=MirsanLab
APP_PUBLIC_URL=http://localhost:4200
APP_BUILD_CONFIGURATION=development

# -----------------------------
# API / Seguridad
# -----------------------------
# Base URL del backend (la variable mas importante por entorno)
APP_API_URL=http://localhost:8080/api

# Clave de almacenamiento local para JWT (si se parametriza en frontend)
APP_AUTH_TOKEN_STORAGE_KEY=auth_token

# -----------------------------
# Contenido institucional (landing/footer)
# -----------------------------
LAB_DISPLAY_NAME=MirsanLab
LAB_ADDRESS_LINE=San Juan 335
LAB_CITY=Quitilipi
LAB_PROVINCE=Chaco
LAB_COUNTRY=Argentina
LAB_CONTACT_TEXT=Consultas y seguimiento de resultados en el portal
LAB_WHATSAPP_URL=#
LAB_INSTAGRAM_URL=#
LAB_FACEBOOK_URL=#

# URL de Google Maps embebido del laboratorio
LAB_MAP_EMBED_URL=https://www.google.com/maps/embed?pb=

# -----------------------------
# Integraciones publicas
# -----------------------------
FONT_AWESOME_CDN_URL=https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css

# Angular CLI analytics (opcional)
NG_CLI_ANALYTICS_ID=

# -----------------------------
# Deploy (contenedor/web server)
# -----------------------------
WEB_SERVER_PORT=80
WEB_SERVER_NAME=localhost

